# Скопируй этот файл в .env.local и заполни значения.
# .env.local в git не попадает (см. .gitignore) — ключи не утекут.

# Включить AI-объяснения находок (по умолчанию выключено — сервис работает и без этого).
AI_EXPLANATIONS_ENABLED=false

# Нужен только если AI_EXPLANATIONS_ENABLED=true. Ключ Anthropic API.
ANTHROPIC_API_KEY=
